# Cliente activo (slug del archivo en clients/)
CLIENT_ID=go-apple

# ── Supabase (necesario para guardar API desde la web) ──
# Usá la clave "service_role" (JWT eyJ…) desde Supabase → Settings → API.
# También acepta SUPABASE_SECRET_KEY si usás las nuevas claves sb_secret_…
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Contraseña para entrar a /settings (solo en servidor, no se guarda en DB)
ADMIN_PASSWORD=tu-password-secreta

# ── Opcional: credenciales Meta por env (si no usás /settings) ──
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
DASHBOARD_PASSWORD=
